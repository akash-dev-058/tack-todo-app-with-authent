DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/auth_todo_db  # PostgreSQL async URL
REDIS_URL=redis://localhost:6379/0  # Redis connection URL
JWT_SECRET_KEY=supersecretkeymustbe32byteslong  # Minimum 32 characters
JWT_ALGORITHM=HS256  # JWT signing algorithm
ACCESS_TOKEN_EXPIRE_MINUTES=30  # Access token lifetime in minutes
REFRESH_TOKEN_EXPIRE_DAYS=7  # Refresh token lifetime in days
FRONTEND_URL=http://localhost:3000  # Allowed CORS origin for frontend
BACKEND_URL=http://localhost:8000  # Backend base URL
SENTRY_DSN=  # Sentry DSN for error tracking (optional)
RESEND_API_KEY=  # Resend API key for email notifications (optional)